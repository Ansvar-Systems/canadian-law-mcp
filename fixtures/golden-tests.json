{
  "$schema": "./golden-tests.schema.json",
  "version": "1.1",
  "mcp_name": "Canadian Law MCP",
  "description": "Golden contract tests for the Canadian Law MCP -- 12 tests covering provision retrieval, search, citation, cross-reference, and negative cases",
  "tests": [
    {
      "id": "ca-001",
      "category": "article_retrieval",
      "description": "Retrieve PIPEDA Section 2 -- purpose and definitions of personal information protection",
      "tool": "get_provision",
      "input": {
        "document_id": "Personal Information Protection and Electronic Documents Act",
        "section": "2"
      },
      "assertions": {
        "result_not_empty": true,
        "text_contains": ["personal information"],
        "citation_url_pattern": "^https://laws-lois\\.justice\\.gc\\.ca/"
      }
    },
    {
      "id": "ca-002",
      "category": "article_retrieval",
      "description": "Retrieve CASL Section 1 -- short title of Canada's Anti-Spam Legislation",
      "tool": "get_provision",
      "input": {
        "document_id": "E-1.6",
        "section": "1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["electronic", "commercial"],
        "text_not_empty": true
      }
    },
    {
      "id": "ca-003",
      "category": "article_retrieval",
      "description": "Retrieve Criminal Code cybercrime section -- unauthorized use of computer (Section 342.1)",
      "tool": "get_provision",
      "input": {
        "document_id": "Criminal Code",
        "section": "342.1"
      },
      "assertions": {
        "result_not_empty": true,
        "any_result_contains": ["computer"],
        "text_not_empty": true
      }
    },
    {
      "id": "ca-004",
      "category": "search",
      "description": "Full-text search for 'personal information' returns PIPEDA and Privacy Act provisions",
      "tool": "search_legislation",
      "input": {
        "query": "personal information"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["personal information"]
      }
    },
    {
      "id": "ca-005",
      "category": "search",
      "description": "Full-text search for 'electronic message' returns CASL provisions",
      "tool": "search_legislation",
      "input": {
        "query": "electronic message"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["electronic message"]
      }
    },
    {
      "id": "ca-006",
      "category": "search",
      "description": "Full-text search for 'computer' returns Criminal Code provisions on computer offences",
      "tool": "search_legislation",
      "input": {
        "query": "computer offence"
      },
      "assertions": {
        "result_not_empty": true,
        "min_results": 1,
        "any_result_contains": ["computer"]
      }
    },
    {
      "id": "ca-007",
      "category": "citation_roundtrip",
      "description": "Citation for PIPEDA Section 5 includes laws-lois.justice.gc.ca URL pattern",
      "tool": "get_provision",
      "input": {
        "document_id": "Personal Information Protection and Electronic Documents Act",
        "section": "5"
      },
      "assertions": {
        "result_not_empty": true,
        "citation_url_pattern": "^https://laws-lois\\.justice\\.gc\\.ca/",
        "text_not_empty": true
      }
    },
    {
      "id": "ca-008",
      "category": "citation_roundtrip",
      "description": "Citation for Privacy Act Section 3 includes official URL and stable identifier",
      "tool": "get_provision",
      "input": {
        "document_id": "Privacy Act",
        "section": "3"
      },
      "assertions": {
        "result_not_empty": true,
        "citation_url_pattern": "^https://laws-lois\\.justice\\.gc\\.ca/",
        "text_not_empty": true
      }
    },
    {
      "id": "ca-009",
      "category": "eu_cross_reference",
      "description": "PIPEDA cross-reference to EU GDPR -- Canada has had an EU adequacy finding for commercial organizations subject to PIPEDA",
      "tool": "get_provision_eu_basis",
      "input": {
        "document_id": "Personal Information Protection and Electronic Documents Act",
        "provision_ref": "s5"
      },
      "assertions": {
        "result_not_empty": true,
        "handles_gracefully": true
      }
    },
    {
      "id": "ca-010",
      "category": "eu_cross_reference",
      "description": "Competition Act cross-reference to EU competition law frameworks",
      "tool": "get_provision_eu_basis",
      "input": {
        "document_id": "Competition Act",
        "provision_ref": "s1"
      },
      "assertions": {
        "result_not_empty": true,
        "handles_gracefully": true
      }
    },
    {
      "id": "ca-011",
      "category": "negative_test",
      "description": "Non-existent Canadian Act returns graceful error or empty result",
      "tool": "get_provision",
      "input": {
        "document_id": "Fictional Maple Syrup Regulation Act 2099",
        "section": "1"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "ca-012",
      "category": "negative_test",
      "description": "Malformed section number returns graceful error or empty result",
      "tool": "get_provision",
      "input": {
        "document_id": "Personal Information Protection and Electronic Documents Act",
        "section": "999ZZZ-INVALID"
      },
      "assertions": {
        "handles_gracefully": true
      }
    }
  ]
}
