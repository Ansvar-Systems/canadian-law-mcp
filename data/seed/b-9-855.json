    {
      "provision_ref": "s190",
      "chapter": "PART 8 Payments to Provinces and Territories",
      "section": "190",
      "title": "Payment of $650,000,000",
      "content": "190 (1) From and out of the Consolidated Revenue Fund, there may, on the requisition of the Minister of Human Resources and Skills Development, be paid to the provinces a payment in the amount of $650,000,000 for the fiscal year beginning on April 1, 2006, in respect of early learning and child care. (2) The payment referred to in subsection (1) shall be allocated to the provinces as follows: (a) to Ontario, $252,933,933.35; (b) to Quebec, $152,740,663.90; (c) to Nova Scotia, $18,743,350.65; (d) to New Brunswick, $15,028,068.42; (e) to Manitoba, $23,683,368.44; (f) to British Columbia, $85,920,064.72; (g) to Prince Edward Island, $2,762,632.45; (h) to Saskatchewan, $19,863,918.85; (i) to Alberta, $65,973,415.33; (j) to Newfoundland and Labrador, $10,266,477.67; (k) to Yukon, $619,370.20; (l) to the Northwest Territories, $862,067.75; and (m) to Nunavut, $602,668.27."
    },
    {
      "provision_ref": "s191",
      "chapter": "PART 8 Payments to Provinces and Territories",
      "section": "191",
      "title": "Payment to territories",
      "content": "191 From and out of the Consolidated Revenue Fund, there may, on the requisition of the Minister of Finance, be paid to the territories the following payments for the fiscal year beginning on April 1, 2006: (a) to Yukon, $10,900,000; (b) to the Northwest Territories, $18,000,000; and (c) to Nunavut, $17,500,000."
    },
